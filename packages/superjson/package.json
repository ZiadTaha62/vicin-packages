{
  "name": "@vicin/superjson",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [],
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest --coverage",
    "test": "vitest --coverage",
    "prepack": "turbo run build --filter=@vicin/superjson",
    "prepublishOnly": "turbo run test --filter=@vicin/superjson",
    "size": "size-limit",
    "bench": "node benchmark.js"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "5 KB"
    }
  ],
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "decimal.js": "^10.6.0",
    "mongodb": "^7.1.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "copy-anything": "^4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ZiadTaha62/vicin-packages.git",
    "directory": "packages/superjson"
  },
  "homepage": "https://github.com/ZiadTaha62/vicin-packages/tree/main/packages/superjson"
}
