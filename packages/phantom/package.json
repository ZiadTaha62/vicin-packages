{
  "name": "@vicin/phantom",
  "version": "1.1.1",
  "description": "Powerful, lightweight TypeScript library for nominal typing.",
  "license": "MIT",
  "author": "Ziad ziadtaha62@gmail.com",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "typescript",
    "nominal-typing",
    "ddd",
    "domain-driven-design",
    "branding",
    "branded-types",
    "type-safety",
    "metadata",
    "type-metadata",
    "identity",
    "traits",
    "type-transformations",
    "state-variants",
    "type-pipe",
    "zero-runtime",
    "type-only"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest --coverage",
    "test:types": "tsd",
    "test": "vitest --coverage && tsd",
    "prepack": "turbo run build --filter=@vicin/phantom",
    "prepublishOnly": "turbo run test --filter=@vicin/phantom",
    "size": "size-limit",
    "bench": "vitest bench --run"
  },
  "tsd": {
    "directory": "tests/types",
    "compilerOptions": {
      "strict": true,
      "esModuleInterop": true,
      "moduleResolution": "node"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ZiadTaha62/vicin-packages.git",
    "directory": "packages/phantom"
  },
  "homepage": "https://github.com/ZiadTaha62/vicin-packages/tree/main/packages/phantom"
}
