{
  "name": "@vicin/ddd-core",
  "version": "1.3.0",
  "description": "Lightweight TypeScript library for nominal identity classes",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ZiadTaha62/ddd-core.git"
  },
  "homepage": "https://github.com/ZiadTaha62/ddd-core#readme",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint --fix",
    "format": "prettier --write",
    "typecheck": "tsc --noEmit",
    "test": "jest --detectOpenHandles tests && tsd",
    "test:types": "tsd",
    "prepublishOnly": "npm run build && npm run test"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "tsd": {
    "directory": "tests/types",
    "compilerOptions": {
      "strict": true,
      "esModuleInterop": true,
      "moduleResolution": "node"
    }
  },
  "keywords": [
    "typescript",
    "nominal-typing",
    "runtime-identity",
    "class-identity",
    "instanceof",
    "cross-bundle",
    "symbol",
    "registry",
    "label-based",
    "type-branding",
    "type-safe",
    "inheritance",
    "domain-driven-design",
    "ddd",
    "monorepo"
  ],
  "author": "Ziad ziadtaha62@gmail.com",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "size-limit": "^12.0.0",
    "ts-jest": "^29.4.6",
    "tsd": "^0.33.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@vicin/sigil": "^3.4.0",
    "fast-deep-equal": "^3.1.3",
    "fast-sort": "^3.4.1",
    "rfdc": "^1.4.1"
  }
}
