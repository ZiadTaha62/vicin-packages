{
  "name": "@vicin/sigil",
  "version": "3.4.0",
  "description": "Sigil, bulletproof class identity for large TypeScript projects",
  "license": "MIT",
  "author": "Ziad ziadtaha62@gmail.com",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "typescript",
    "nominal-typing",
    "runtime-identity",
    "class-identity",
    "instanceof",
    "cross-bundle",
    "symbol",
    "registry",
    "label-based",
    "type-branding",
    "type-safe",
    "inheritance",
    "domain-driven-design",
    "ddd",
    "monorepo"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest --coverage",
    "test:types": "tsd",
    "test": "vitest --coverage && tsd",
    "prepack": "turbo run build --filter=@vicin/sigil",
    "prepublishOnly": "turbo run test --filter=@vicin/sigil",
    "size": "size-limit",
    "bench": "vitest bench --run",
    "bench:creation": "vitest bench --run bench/creation.bench.ts",
    "bench:instanceof": "vitest bench --run bench/creation.instanceof.ts"
  },
  "tsd": {
    "directory": "tests/types",
    "compilerOptions": {
      "strict": true,
      "esModuleInterop": true,
      "moduleResolution": "node"
    }
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "1 KB"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ZiadTaha62/vicin-packages.git",
    "directory": "packages/sigil"
  },
  "homepage": "https://github.com/ZiadTaha62/vicin-packages/tree/main/packages/sigil"
}
