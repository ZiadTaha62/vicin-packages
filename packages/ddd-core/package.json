{
  "name": "@vicin/ddd-core",
  "version": "1.0.0",
  "description": "",
  "license": "MIT",
  "author": "Ziad ziadtaha62@gmail.com",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [],
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest --coverage",
    "test": "vitest --coverage --passWithNoTests",
    "prepack": "turbo run build --filter=@vicin/ddd-core",
    "prepublishOnly": "turbo run test --filter=@vicin/ddd-core",
    "size": "size-limit",
    "bench": "vitest bench --run"
  },
  "tsd": {
    "directory": "tests/types",
    "compilerOptions": {
      "strict": true,
      "esModuleInterop": true,
      "moduleResolution": "node"
    }
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "100 KB"
    }
  ],
  "dependencies": {
    "@vicin/sigil": "workspace:*",
    "fast-deep-equal": "^3.1.3",
    "fast-sort": "^3.4.1",
    "rfdc": "^1.4.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ZiadTaha62/vicin-packages.git",
    "directory": "packages/ddd-core"
  },
  "homepage": "https://github.com/ZiadTaha62/vicin-packages/tree/main/packages/ddd-core"
}
