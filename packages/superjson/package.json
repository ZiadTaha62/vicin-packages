{
  "name": "@vicin/superjson",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest --coverage",
    "test": "vitest --coverage",
    "prepack": "turbo run build --filter=@vicin/superjson",
    "prepublishOnly": "turbo run test --filter=@vicin/superjson",
    "size": "size-limit",
    "bench": "node benchmark.js"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "5 KB"
    }
  ],
  "devDependencies": {
    "@types/debug": "^4.1.5",
    "@types/mongodb": "^3.6.12",
    "decimal.js": "^10.3.1",
    "mongodb": "^3.6.6"
  },
  "dependencies": {
    "copy-anything": "^4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ZiadTaha62/vicin-packages.git",
    "directory": "packages/superjson"
  },
  "homepage": "https://github.com/ZiadTaha62/vicin-packages/tree/main/packages/superjson"
}
